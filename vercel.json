{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.riyakadev.com" }],
      "destination": "https://riyakadev.com/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog/index.html",
      "destination": "/blog/",
      "permanent": true
    },
    {
      "source": "/tools/index.html",
      "destination": "/tools/",
      "permanent": true
    }
  ]
}
